{
  "name": "@yansircc/pi-weixin",
  "version": "0.0.2",
  "description": "Weixin iLink bridge for Pi sessions hosted by pi-web",
  "keywords": [
    "ilink",
    "pi-package",
    "weixin"
  ],
  "homepage": "https://github.com/yansircc/pi-weixin#readme",
  "bugs": {
    "url": "https://github.com/yansircc/pi-weixin/issues"
  },
  "license": "MIT",
  "author": "yansircc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yansircc/pi-weixin.git"
  },
  "files": [
    "dist/pi",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "effect-tsgo patch",
    "build": "vp run ci:build",
    "bundle:check": "vp run ci:bundle",
    "check": "vp check",
    "distribution:check": "vp run ci:distribution",
    "effect:scan": "vp run ci:effect",
    "pack:plugin": "pnpm pack --out pi-weixin-%v.tgz",
    "test": "vp test",
    "typecheck": "vp run ci:typecheck",
    "verify": "vp run ci:verify",
    "prepack": "vp run ci:build && vp run ci:bundle"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@effect/opentelemetry": "4.0.0-beta.98",
    "@effect/platform-node": "4.0.0-beta.98",
    "@effect/tsgo": "0.21.0",
    "@effect/vitest": "4.0.0-beta.98",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/api-logs": "0.217.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-logs": "0.217.0",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/sdk-trace-web": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@types/node": "^25.0.0",
    "@types/qrcode": "^1.5.6",
    "acorn": "8.15.0",
    "effect": "4.0.0-beta.98",
    "qrcode": "^1.5.4",
    "typescript": "7.0.2",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.19.0 || >=24.11.0"
  },
  "packageManager": "pnpm@10.11.0",
  "ilink": {
    "appId": "bot",
    "clientVersion": "2.4.6"
  },
  "pi": {
    "extensions": [
      "./dist/pi/extension.js"
    ]
  }
}
