{
  "name": "@agegr/pi-weixin",
  "version": "0.0.1",
  "description": "Text-only Weixin iLink bridge for Pi sessions hosted by pi-web",
  "keywords": [
    "ilink",
    "pi-package",
    "weixin"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "vp run ci:build",
    "check": "vp check",
    "effect:scan": "vp run ci:effect",
    "smoke": "vp run ci:smoke",
    "test": "vp test",
    "typecheck": "vp run ci:typecheck",
    "verify": "vp run ci:verify",
    "prepack": "vp run ci:build && vp run ci:smoke"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.98",
    "effect": "4.0.0-beta.98",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@effect/language-service": "0.87.0",
    "@effect/opentelemetry": "4.0.0-beta.98",
    "@effect/vitest": "4.0.0-beta.98",
    "@types/node": "^25.0.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "5.9.3",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6"
  },
  "engines": {
    "node": "^22.19.0 || >=24.11.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pi": {
    "extensions": [
      "./dist/weixin.mjs"
    ]
  }
}
